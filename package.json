{
	"name": "@nuasite/oss",
	"type": "module",
	"private": true,
	"version": "0.30.0",
	"scripts": {
		"build": "bun run ts:build && bun run --filter './packages/*' build",
		"clean": "bun run clean:generated && bun run clean:dependencies",
		"clean:dependencies": "rm -rf packages/*/node_modules || true; rm -rf node_modules || true",
		"clean:generated": "rm -rf dist || true; rm -rf packages/*/dist || true; rm -rf packages/*/temp || true",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"lint:deps": "deptective",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"test": "bun test --conditions=typescript packages",
		"ts:build": "tsc --build",
		"ts:watch": "tsc --build --watch",
		"ts:clean": "tsc --build --clean"
	},
	"devDependencies": {
		"@actions/core": "catalog:build",
		"@happy-dom/global-registrator": "catalog:tests",
		"@types/bun": "catalog:build",
		"@types/js-yaml": "catalog:build",
		"deptective": "catalog:build",
		"dprint": "catalog:build",
		"happy-dom": "catalog:tests",
		"js-yaml": "catalog:build",
		"json5": "catalog:build",
		"oxlint": "^1.59.0",
		"typescript": "catalog:build"
	},
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalogs": {
			"build": {
				"@actions/core": "^3.0.0",
				"@biomejs/biome": "^2.4.9",
				"@types/bun": "1.3.11",
				"@types/js-yaml": "^4.0.9",
				"deptective": "^0.2.1",
				"dprint": "^0.53.2",
				"js-yaml": "^4.1.0",
				"json5": "^2.2.3",
				"typescript": "^6.0.2",
				"vite": "^7.0.0"
			},
			"astro": {
				"@astrojs/check": "0.9.8",
				"@astrojs/compiler": "^3.0.1",
				"@astrojs/mdx": "5.0.3",
				"@astrojs/sitemap": "3.7.2",
				"astro": "6.1.4"
			},
			"parsers": {
				"@babel/parser": "^7.29.2",
				"node-html-parser": "^7.1.0",
				"stacktracey": "2.2.0",
				"yaml": "^2.8.3"
			},
			"ui": {
				"@tailwindcss/vite": "^4.2.2",
				"@tailwindcss/typography": "^0.5.19",
				"flowbite": "4.0.1",
				"tailwindcss": "4.2.2"
			},
			"tests": {
				"happy-dom": "^20.8.9",
				"@happy-dom/global-registrator": "^20.8.9"
			},
			"editor": {
				"@milkdown/core": "^7.20.0",
				"@milkdown/ctx": "^7.20.0",
				"@milkdown/plugin-listener": "^7.20.0",
				"@milkdown/preset-commonmark": "^7.20.0",
				"@milkdown/preset-gfm": "^7.20.0",
				"@milkdown/prose": "^7.20.0",
				"@milkdown/transformer": "^7.20.0",
				"@milkdown/utils": "^7.20.0",
				"@preact/signals": "^2.9.0",
				"@tailwindcss/postcss": "^4.1.17",
				"autoprefixer": "^10.4.22",
				"clsx": "^2.1.1",
				"marked": "^18.0.0",
				"postcss": "^8",
				"preact": "^10.29.1",
				"prosemirror-commands": "^1.7.1",
				"prosemirror-inputrules": "^1.5.1",
				"prosemirror-keymap": "^1.2.3",
				"prosemirror-model": "^1.25.4",
				"prosemirror-safari-ime-span": "^1.0.2",
				"prosemirror-schema-list": "^1.5.1",
				"prosemirror-state": "^1.4.4",
				"prosemirror-transform": "^1.12.0",
				"prosemirror-view": "^1.41.8",
				"remark-mdx": "^3.1.0",
				"tailwind-merge": "^3.5.0"
			}
		}
	}
}
